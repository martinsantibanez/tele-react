PORT=3000
HOST=localhost
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=

# YouTube "subscribed channels live now" — OAuth (Google Cloud project with
# YouTube Data API v3 enabled, OAuth client of type "Web application" whose
# Authorized redirect URI is <origin>/api/youtube/callback).
# Client id is public; the secret is server-only and stays out of the bundle.
NEXT_PUBLIC_YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# 32-byte key used to encrypt the refresh token stored in the session cookie.
# Generate with: openssl rand -base64 32
YOUTUBE_TOKEN_SECRET=
